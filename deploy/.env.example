# ByteCoach Production Environment Variables
# Copy this file to .env and fill in the values

# Database
BYTECOACH_DB_NAME=bytecoach
BYTECOACH_DB_USERNAME=bytecoach
BYTECOACH_DB_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=change_me_in_production

# Redis
BYTECOACH_REDIS_PASSWORD=

# JWT — MUST be changed, minimum 32 characters
BYTECOACH_JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# CORS — comma-separated list of allowed origins
BYTECOACH_CORS_ORIGINS=https://your-domain.com

# LLM
BYTECOACH_LLM_ENABLED=true
BYTECOACH_LLM_BASE_URL=https://api.openai.com/v1
BYTECOACH_LLM_API_KEY=sk-your-api-key
BYTECOACH_LLM_MODEL=gpt-4.1-mini

# Ports
BYTECOACH_HTTP_PORT=80
BYTECOACH_BACKEND_PORT=8080
BYTECOACH_DB_PORT=3306
BYTECOACH_REDIS_PORT=6379
