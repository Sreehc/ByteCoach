# OfferPilot Production Environment Variables
# Copy this file to .env and fill in the values

# Host MySQL (Baota / host machine)
OFFERPILOT_DB_HOST=127.0.0.1
OFFERPILOT_DB_PORT=3306
OFFERPILOT_DB_NAME=offerpilot
OFFERPILOT_DB_USERNAME=offerpilot
OFFERPILOT_DB_PASSWORD=change_me_in_production

# Redis Stack
# OfferPilot uses a dedicated redis/redis-stack-server container with
# RediSearch and RedisJSON modules. Do not point it at a plain Redis instance.
OFFERPILOT_REDIS_HOST=127.0.0.1
OFFERPILOT_REDIS_PORT=6380
OFFERPILOT_REDIS_PASSWORD=

# JWT — MUST be changed, minimum 32 characters
OFFERPILOT_JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# CORS — comma-separated list of allowed origins
OFFERPILOT_CORS_ORIGINS=https://your-domain.com

# LLM
OFFERPILOT_LLM_ENABLED=false
OFFERPILOT_LLM_BASE_URL=https://api.openai.com/v1
OFFERPILOT_LLM_API_KEY=
OFFERPILOT_LLM_MODEL=gpt-4.1-mini

# Embedding
OFFERPILOT_EMBEDDING_ENABLED=false

# Ports
OFFERPILOT_HTTP_BIND_HOST=127.0.0.1
OFFERPILOT_HTTP_PORT=8092
OFFERPILOT_BACKEND_BIND_HOST=127.0.0.1
OFFERPILOT_BACKEND_PORT=8080

# Optional image override for GHCR-based deployment
OFFERPILOT_BACKEND_IMAGE=ghcr.io/sreehc/offerpilot-backend:latest
OFFERPILOT_FRONTEND_IMAGE=ghcr.io/sreehc/offerpilot-frontend:latest
