# ByteCoach Production Environment Variables
# Copy this file to .env and fill in the values

# Host MySQL (Baota / host machine)
BYTECOACH_DB_HOST=127.0.0.1
BYTECOACH_DB_PORT=3306
BYTECOACH_DB_NAME=bytecoach
BYTECOACH_DB_USERNAME=bytecoach
BYTECOACH_DB_PASSWORD=change_me_in_production

# Redis Stack
# ByteCoach uses a dedicated redis/redis-stack-server container with
# RediSearch and RedisJSON modules. Do not point it at a plain Redis instance.
BYTECOACH_REDIS_HOST=127.0.0.1
BYTECOACH_REDIS_PORT=6380
BYTECOACH_REDIS_PASSWORD=

# JWT — MUST be changed, minimum 32 characters
BYTECOACH_JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# CORS — comma-separated list of allowed origins
BYTECOACH_CORS_ORIGINS=https://your-domain.com

# LLM
BYTECOACH_LLM_ENABLED=false
BYTECOACH_LLM_BASE_URL=https://api.openai.com/v1
BYTECOACH_LLM_API_KEY=
BYTECOACH_LLM_MODEL=gpt-4.1-mini

# Embedding
BYTECOACH_EMBEDDING_ENABLED=false

# Ports
BYTECOACH_HTTP_BIND_HOST=127.0.0.1
BYTECOACH_HTTP_PORT=8092
BYTECOACH_BACKEND_BIND_HOST=127.0.0.1
BYTECOACH_BACKEND_PORT=8080

# Optional image override for GHCR-based deployment
BYTECOACH_BACKEND_IMAGE=ghcr.io/sreehc/bytecoach-backend:latest
BYTECOACH_FRONTEND_IMAGE=ghcr.io/sreehc/bytecoach-frontend:latest
