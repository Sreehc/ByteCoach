# ByteCoach 环境变量模板
# 复制此文件为 .env 并填写实际值:  cp .env.example .env

# ═══════════════════════════════════════
# 必填项（不设置会启动失败）
# ═══════════════════════════════════════

# MySQL root 密码
MYSQL_ROOT_PASSWORD=change_me_root_password

# MySQL 业务数据库密码
BYTECOACH_DB_PASSWORD=change_me_db_password

# JWT 签名密钥（至少 32 字符）
BYTECOACH_JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# CORS 允许的前端域名（逗号分隔）
BYTECOACH_CORS_ORIGINS=http://localhost

# LLM API Key（面试评分、计划生成等功能依赖）
BYTECOACH_LLM_API_KEY=sk-your-api-key

# ═══════════════════════════════════════
# 数据库
# ═══════════════════════════════════════

BYTECOACH_DB_NAME=bytecoach
BYTECOACH_DB_USERNAME=bytecoach

# ═══════════════════════════════════════
# Redis
# ═══════════════════════════════════════

# Redis 密码（可选，留空表示无密码）
BYTECOACH_REDIS_PASSWORD=

# ═══════════════════════════════════════
# JWT
# ═══════════════════════════════════════

# Token 有效期（秒），默认 24 小时
BYTECOACH_JWT_EXPIRE_SECONDS=86400

# ═══════════════════════════════════════
# LLM / AI
# ═══════════════════════════════════════

BYTECOACH_LLM_ENABLED=true
BYTECOACH_LLM_BASE_URL=https://api.openai.com/v1
BYTECOACH_LLM_MODEL=gpt-4.1-mini
BYTECOACH_LLM_TIMEOUT_SECONDS=30

# Embedding（向量搜索，可选）
BYTECOACH_EMBEDDING_ENABLED=false
BYTECOACH_EMBEDDING_MODEL=text-embedding-3-small
BYTECOACH_EMBEDDING_DIMENSIONS=1536
BYTECOACH_VECTOR_THRESHOLD=0.3

# ═══════════════════════════════════════
# 端口
# ═══════════════════════════════════════

# 前端 HTTP 端口
BYTECOACH_HTTP_PORT=80

# ═══════════════════════════════════════
# 业务参数（可选，有合理默认值）
# ═══════════════════════════════════════

# 面试评分：低于此分自动加入错题本
# BYTECOACH_WRONG_THRESHOLD=60

# AI 每日调用上限（每用户）
# BYTECOACH_AI_QUOTA=100

# 限流：每 IP 每分钟最大请求数
# BYTECOACH_RATE_LIMIT=60
# BYTECOACH_RATE_WINDOW=60

# 每日复习最大题数
# BYTECOACH_REVIEW_DAILY_LIMIT=30

# Dashboard 缓存时间（分钟）
# BYTECOACH_DASHBOARD_CACHE_TTL=5
